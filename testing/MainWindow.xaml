<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PLC Production Monitor" 
        Height="768" Width="1024"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#303030"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Viewbox Stretch="Fill">

        <Grid Height="768" Width="1024" Background="LightGray">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#000080" BorderBrush="White" BorderThickness="0,0,0,2">
                <Grid Margin="20,0">
                    <TextBlock Text="URETHANE DOOR MONITORING SYSTEM" 
                               VerticalAlignment="Center" HorizontalAlignment="Left" 
                               FontSize="32" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Name="LabelWaktu" Text="--:--:--" 
                               VerticalAlignment="Center" HorizontalAlignment="Right" 
                               FontSize="28" FontWeight="Bold" Foreground="White"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <DataGrid Grid.Column="0" x:Name="GridDelivered"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="All"
                          RowHeight="72" FontSize="24" FontWeight="Bold"
                          BorderBrush="Green" BorderThickness="3"
                          IsHitTestVisible="False" Focusable="False"
                          SelectionMode="Single" RowBackground="White"
                          VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Green"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="26"/>
                            <Setter Property="Height" Value="50"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DELIVERED" Binding="{Binding Value}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="Green"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Height="50" Background="Navy" BorderBrush="White" BorderThickness="0,0,1,0">
                        <TextBlock Text="ORDERS" 
                                   Foreground="White" FontSize="26" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="GridOrder"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              HeadersVisibility="None" GridLinesVisibility="All"
                              RowHeight="72" FontSize="24" FontWeight="Bold"
                              BorderBrush="Navy" BorderThickness="3,0,3,3"
                              IsHitTestVisible="False" Focusable="False"
                              SelectionMode="Single" RowBackground="White"
                              VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Value1}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="Navy"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Binding="{Binding Value2}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="Blue"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

            </Grid>

            <StatusBar Grid.Row="2" Background="Black">
                <TextBlock x:Name="LabelStatus" Text="Menunggu..." 
                           FontSize="24" FontWeight="Bold" 
                           VerticalAlignment="Center" Margin="20,0"/>
            </StatusBar>
        </Grid>
    </Viewbox>
</Window>