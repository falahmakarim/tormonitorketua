<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PLC Production Monitor" 
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        Background="#ffffff"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        FontFamily="Bebas Neue">
    <Grid Background="#ffffff">
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0066cc" BorderThickness="0,0,0,5" BorderBrush="#004d99">
            <DockPanel Margin="20,0">
                <TextBlock Text="URETHANE DOOR MONITORING SYSTEM" 
                           DockPanel.Dock="Left" VerticalAlignment="Center" 
                           FontSize="42" FontWeight="Normal" Foreground="#FFFFFF"
                           FontFamily="Bebas Neue"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Name="BtnDeliver" Content="DELIVER" Click="BtnDeliver_Click" 
                            Width="140" Height="55" Margin="0,0,20,0" 
                            FontSize="26" Foreground="#0066cc" Background="#ffffff" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Border Background="#ffffff" CornerRadius="10" Padding="15,5">
                        <TextBlock Name="LabelWaktu" Text="--:--:--" 
                                   FontSize="40" Foreground="#0066cc" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#228B22" BorderThickness="3" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="55"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#228B22">
                        <TextBlock Text="DELIVERED" FontSize="30" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <DataGrid Grid.Row="1" x:Name="GridDelivered" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="None" GridLinesVisibility="All" FontSize="32" IsHitTestVisible="False" Focusable="False" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <DataGrid.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="1" Rows="8"/>
                            </ItemsPanelTemplate>
                        </DataGrid.ItemsPanel>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Value}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="#0066cc" BorderThickness="3" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="55"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#0066cc">
                        <TextBlock Text="ORDERS" FontSize="30" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <DataGrid Grid.Row="1" x:Name="GridOrder" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="None" GridLinesVisibility="All" FontSize="32" IsHitTestVisible="False" Focusable="False" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <DataGrid.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="1" Rows="8"/>
                            </ItemsPanelTemplate>
                        </DataGrid.ItemsPanel>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Value1}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding Value2}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Expander Grid.Row="2" Header="SHOW / HIDE SYSTEM INFORMATION" 
                  FontSize="18" Foreground="#0066cc" Background="#f8f9fa" 
                  IsExpanded="False" Margin="15,0,15,10"
                  Focusable="False" Expanded="Expander_Expanded" Collapsed="Expander_Collapsed">
            <Border BorderBrush="#dddddd" BorderThickness="0,2,0,0" Background="#ffffff" Padding="15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Border BorderBrush="#0066cc" BorderThickness="0,0,0,3" Margin="0,0,10,10">
                            <TextBlock Text="PLC CONNECTION" FontSize="22" Foreground="#0066cc"/>
                        </Border>
                        <DockPanel Margin="0,2">
                            <TextBlock Text="IP Address: " FontSize="18" Foreground="#666666" VerticalAlignment="Center" Width="100"/>
                            <TextBox x:Name="TxtIPAddress" Text="127.0.0.1" FontSize="18" FontWeight="Bold" BorderThickness="1" VerticalContentAlignment="Center" LostFocus="Input_LostFocus"/>
                        </DockPanel>
                        <DockPanel Margin="0,2">
                            <TextBlock Text="Port: " FontSize="18" Foreground="#666666" VerticalAlignment="Center" Width="100"/>
                            <TextBox x:Name="TxtPort" Text="8501" FontSize="18" FontWeight="Bold" BorderThickness="1" VerticalContentAlignment="Center" LostFocus="Input_LostFocus"/>
                        </DockPanel>
                        <TextBlock FontSize="18" Margin="0,2"><Run Text="Status: " Foreground="#666666"/><Run x:Name="InfoConnStatus" Text="OFFLINE" Foreground="#FF0000" FontWeight="Bold"/></TextBlock>
                        <TextBlock FontSize="18" Margin="0,2"><Run Text="Uptime: " Foreground="#666666"/><Run Name="InfoUptime" Text="00:00:00" FontWeight="Bold"/></TextBlock>
                    </StackPanel>

                    <Grid Grid.Column="1" Margin="10,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="17" Margin="0,2"><Run Text="Protocol: " Foreground="#666666"/><Run Text="TCP/IP" FontWeight="Bold"/></TextBlock>
                            <TextBlock FontSize="17" Margin="0,2"><Run Text="Format: " Foreground="#666666"/><Run Text="Dec (16-bit)" FontWeight="Bold"/></TextBlock>
                            <DockPanel Margin="0,2">
                                <TextBlock Text="Mem Addr: " FontSize="17" Foreground="#666666" VerticalAlignment="Center" Width="90"/>
                                <TextBox x:Name="TxtMemAddr" Text="DM600" FontSize="17" FontWeight="Bold" BorderThickness="1" VerticalContentAlignment="Center" LostFocus="Input_LostFocus"/>
                            </DockPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Name="BtnSetPath" Content="SET PATH" Click="BtnSetPath_Click" Width="90" Height="30" Margin="0,0,5,0" Background="#FF8C00" Foreground="White" FontSize="14" Focusable="False"/>
                                <Button Name="BtnExport" Content="OPEN LOG" Click="BtnOpenLog_Click" Width="90" Height="30" Background="#228B22" Foreground="White" FontSize="14" Focusable="False"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="2">
                        <Border BorderBrush="#0066cc" BorderThickness="0,0,0,3" Margin="0,0,10,10">
                            <TextBlock Text="LAST DATA RECEIVED" FontSize="22" Foreground="#0066cc"/>
                        </Border>
                        <TextBox x:Name="TextBoxRawData" Background="#f0f8ff" Foreground="#0066cc" BorderBrush="#0066cc" BorderThickness="2" Padding="10" Height="85" IsReadOnly="True" FontSize="20" FontWeight="Bold" VerticalContentAlignment="Center" TextWrapping="Wrap" Focusable="False" FontFamily="Consolas"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Expander>

        <StatusBar Grid.Row="3" x:Name="BottomStatusBar" Background="#0066cc">
            <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=StatusBar}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="LabelStatus" Grid.Column="0"
                   Text="WAITING FOR CONNECTION..." 
                   FontSize="26" Foreground="#FFFFFF" 
                   FontFamily="Bebas Neue"
                   Margin="20,0" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="MUH NABIL FALAH MAKARIM" 
                       FontSize="14" Foreground="#FFFFFF" 
                       FontFamily="Bebas Neue" HorizontalAlignment="Right" Opacity="0.9"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Politeknik Elektronika Negeri Surabaya" 
                           FontSize="14" Foreground="#FFFFFF" 
                           FontFamily="Bebas Neue" Opacity="0.7"/>
                        <TextBlock Text=" - " FontSize="12" Foreground="#FFFFFF" Opacity="0.7"/>
                        <TextBlock Text="2026" 
                           FontSize="14" Foreground="#FFFFFF" 
                           FontFamily="Bebas Neue" Opacity="0.7"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </StatusBar>
    </Grid>
</Window>