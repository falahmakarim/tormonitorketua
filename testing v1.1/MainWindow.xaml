<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PLC Production Monitor" 
        Height="900" Width="1280"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#ffffff"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Viewbox Stretch="Fill">
        <Grid Height="900" Width="1280" Background="#ffffff">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0066cc" BorderBrush="#0066cc" BorderThickness="0,0,0,5">
                <Grid Margin="20,0">
                    <TextBlock Text="URETHANE DOOR MONITORING SYSTEM" 
                               VerticalAlignment="Center" HorizontalAlignment="Left" 
                               FontSize="40" FontWeight="Bold" Foreground="#FFFFFF"
                               FontFamily="Comic Sans MS"
                               Effect="{x:Null}"/>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Orientation="Horizontal">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Name="LabelWaktu" Text="--:--:--" 
                                       FontSize="36" FontWeight="Bold" Foreground="#0066cc"
                                       FontFamily="Comic Sans MS" Background="#ffffff" Padding="10,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#228B22" BorderThickness="3" Background="#ffffff">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#228B22">
                            <TextBlock Text="DELIVERED" FontSize="28" FontWeight="Bold" 
                                       Foreground="#ffffff" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontFamily="Comic Sans MS"/>
                        </Border>
                        <DataGrid Grid.Row="1" x:Name="GridDelivered"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  HeadersVisibility="None" GridLinesVisibility="All"
                                  FontSize="20" FontWeight="Bold"
                                  IsHitTestVisible="False" Focusable="False"
                                  SelectionMode="Single" RowBackground="#ffffff"
                                  VerticalAlignment="Stretch"
                                  VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
                            <DataGrid.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1" Rows="8"/>
                                </ItemsPanelTemplate>
                            </DataGrid.ItemsPanel>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Value}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#000000"/>
                                            <Setter Property="FontFamily" Value="Comic Sans MS"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" BorderBrush="#0066cc" BorderThickness="3" Background="#ffffff">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#0066cc">
                            <TextBlock Text="ORDERS" FontSize="24" FontWeight="Bold" 
                                       Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontFamily="Comic Sans MS"/>
                        </Border>
                        <DataGrid Grid.Row="1" x:Name="GridOrder"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  HeadersVisibility="None" GridLinesVisibility="All"
                                  FontSize="20" FontWeight="Bold"
                                  IsHitTestVisible="False" Focusable="False"
                                  SelectionMode="Single" RowBackground="#ffffff"
                                  VerticalAlignment="Stretch"
                                  VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
                            <DataGrid.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1" Rows="8"/>
                                </ItemsPanelTemplate>
                            </DataGrid.ItemsPanel>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Value1}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#000000"/>
                                            <Setter Property="FontFamily" Value="Comic Sans MS"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Value2}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#000000"/>
                                            <Setter Property="FontFamily" Value="Comic Sans MS"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" BorderBrush="#dddddd" BorderThickness="0,2,0,0" Background="#ffffff" Margin="15,0,15,15">
                <Grid Margin="15,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,10,0,0">
                        <Border BorderBrush="#0066cc" BorderThickness="0,0,0,3" Padding="0,0,0,5" Margin="0,0,0,10">
                            <TextBlock Text="PLC CONNECTION" FontSize="18" FontWeight="Bold" Foreground="#0066cc" FontFamily="Comic Sans MS"/>
                        </Border>
                        <TextBlock Foreground="#000000" FontFamily="Comic Sans MS" FontSize="16" Margin="0,3">
                            <Run Text="PLC IP Address: " Foreground="#666666"/><Run Name="InfoIPAddress" Text="127.0.0.1" Foreground="#0066cc" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Foreground="#000000" FontFamily="Comic Sans MS" FontSize="16" Margin="0,3">
                            <Run Text="Port: " Foreground="#666666"/><Run Name="InfoPort" Text="8501" Foreground="#0066cc" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Foreground="#000000" FontFamily="Comic Sans MS" FontSize="16" Margin="0,3">
                            <Run Text="Status: " Foreground="#666666"/><Run Name="InfoConnStatus" Text="OFFLINE" Foreground="#FF0000" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Foreground="#000000" FontFamily="Comic Sans MS" FontSize="16" Margin="0,3">
                            <Run Text="Uptime: " Foreground="#666666"/><Run Name="InfoUptime" Text="00:00:00" Foreground="#0066cc" FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="0,10,0,0">

                        <Border Height="42" Visibility="Hidden" Margin="0,0,0,10"/>

                        <TextBlock Name="InfoWordCount" Text="10" Visibility="Collapsed"/>

                        <TextBlock Foreground="#000000" FontFamily="Comic Sans MS" FontSize="16" Margin="0,3">
                            <Run Text="Protocol: " Foreground="#666666"/>
                            <Run Text="TCP/IP" Foreground="#0066cc" FontWeight="Bold"/>
                        </TextBlock>

                        <TextBlock Foreground="#000000" FontFamily="Comic Sans MS" FontSize="16" Margin="0,3">
                            <Run Text="Format: " Foreground="#666666"/>
                            <Run Text="Decimal (16-bit)" Foreground="#0066cc" FontWeight="Bold"/>
                        </TextBlock>

                        <TextBlock Foreground="#000000" FontFamily="Comic Sans MS" FontSize="16" Margin="0,3">
                            <Run Text="Mem Addr: " Foreground="#666666"/>
                            <Run Name="InfoMemAddr" Text="DM600" Foreground="#0066cc" FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="4" VerticalAlignment="Top" Margin="0,10,0,0">
                        <Border BorderBrush="#0066cc" BorderThickness="0,0,0,3" Padding="0,0,0,5" Margin="0,0,0,10">
                            <TextBlock Text="LAST DATA RECEIVED" FontSize="18" FontWeight="Bold" Foreground="#0066cc" FontFamily="Comic Sans MS"/>
                        </Border>
                        <TextBox Name="TextBoxRawData" 
                                 Background="#f0f8ff" 
                                 Foreground="#0066cc" 
                                 BorderBrush="#0066cc" BorderThickness="2"
                                 Padding="10" Height="80" 
                                 IsReadOnly="True" 
                                 FontFamily="Comic Sans MS" 
                                 FontSize="26" FontWeight="Bold"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StatusBar Grid.Row="3" Background="#0066cc">
                <TextBlock x:Name="LabelStatus" 
                           Text="Initializing..." 
                           FontSize="20" FontWeight="Bold" 
                           Foreground="#FFFFFF" 
                           FontFamily="Comic Sans MS" 
                           Margin="20,0"
                           VerticalAlignment="Center"/>
            </StatusBar>
        </Grid>
    </Viewbox>
</Window>